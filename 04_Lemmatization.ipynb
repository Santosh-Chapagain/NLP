    "\n",
    "nlp = spacy.load(\"en_core_web_sm\")\n",
    "\n",
    "doc = nlp(\"running played studies better\")\n",
    "\n",
    "for token in doc:\n",
    "    print(token.text, \"→\", token.lemma_)"
